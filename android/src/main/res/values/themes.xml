<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- No animation theme for AlarmActivity to avoid slide transition -->
    <style name="AlarmNoAnimationTheme" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowAnimationStyle">@style/NoAnimation</item>
    </style>

    <style name="NoAnimation">
        <item name="android:activityOpenEnterAnimation">@android:anim/no_animation</item>
        <item name="android:activityOpenExitAnimation">@android:anim/no_animation</item>
        <item name="android:activityCloseEnterAnimation">@android:anim/no_animation</item>
        <item name="android:activityCloseExitAnimation">@android:anim/no_animation</item>
        <item name="android:taskOpenEnterAnimation">@android:anim/no_animation</item>
        <item name="android:taskOpenExitAnimation">@android:anim/no_animation</item>
        <item name="android:taskCloseEnterAnimation">@android:anim/no_animation</item>
        <item name="android:taskCloseExitAnimation">@android:anim/no_animation</item>
        <item name="android:taskToFrontEnterAnimation">@android:anim/no_animation</item>
        <item name="android:taskToFrontExitAnimation">@android:anim/no_animation</item>
        <item name="android:taskToBackEnterAnimation">@android:anim/no_animation</item>
        <item name="android:taskToBackExitAnimation">@android:anim/no_animation</item>
    </style>
</resources>
